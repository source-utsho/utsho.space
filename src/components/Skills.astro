---
import { skills } from "../config";
import SectionHead from "./SectionHead.astro";
---

<section id="skills">
  <div class="wrap">
    <SectionHead num="05" title="Toolkit" />
    <div class="skills-grid">
      {
        skills.map((g, i) => (
          <div class="skill-group reveal" data-d={(i % 2 + 1).toString()}>
            <h4>{g.group}</h4>
            <ul>
              {g.items.map((it) => (
                <li>{it}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
