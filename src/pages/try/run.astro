---
// THROWAWAY PROTOTYPE — "THE RUN" hero.
// The site's own rendering technology upgrades as his life acquires computing:
// ink (2014) -> CRT phosphor (laptop) -> NASA telemetry (2020) -> GPU (now).
// Warm and biographical by design. Not the real site; a feel-test.
import { meta } from "../../data/portfolio";
const calKeys = ["prefrontal","broca","motor","hippocampus","occipital","cerebellum"];
---
<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>THE RUN — prototype · utsho.space</title>
<meta name="robots" content="noindex" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&family=Instrument+Serif:ital@0;1&family=Caveat:wght@500;600&display=swap" rel="stylesheet" />
<style>
  *{box-sizing:border-box;margin:0}
  :root{--ink:#2b2620;--paper:#ece2cd;--phos:#86ffae;--amber:#ffb454;--vec:#5fd0ff;--gpu:#0a0a0c;}
  html{scroll-behavior:smooth}
  body{background:#0a0a0c;color:#fff;font-family:'IBM Plex Sans',system-ui,sans-serif;-webkit-font-smoothing:antialiased}
  .era{min-height:100vh;position:relative;overflow:hidden;display:flex;flex-direction:column;justify-content:center;padding:6vh 7vw}
  .yr{position:absolute;top:4vh;right:7vw;font-family:'IBM Plex Mono',monospace;font-size:clamp(2.2rem,7vw,5rem);font-weight:500;opacity:.18;letter-spacing:-.02em}
  .cap{font-family:'Instrument Serif',Georgia,serif;font-size:clamp(1.3rem,3vw,2.1rem);line-height:1.35;max-width:24ch;margin-top:1.4rem}
  .tag{font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.2em;text-transform:uppercase;opacity:.6;margin-bottom:1.2rem}
  .reveal{opacity:0;transform:translateY(26px);transition:opacity 1s ease,transform 1s cubic-bezier(.2,.8,.2,1)}
  .reveal.in{opacity:1;transform:none}

  /* ---- ERA 1 · INK (2014) — warm paper ---- */
  .e-ink{background:
      linear-gradient(rgba(120,90,40,.05),rgba(120,90,40,.05)),
      repeating-linear-gradient(0deg,transparent 0 27px,rgba(80,60,30,.10) 27px 28px),
      repeating-linear-gradient(90deg,transparent 0 27px,rgba(80,60,30,.06) 27px 28px),
      var(--paper);
    color:var(--ink)}
  .e-ink .yr{color:var(--ink)}
  .ink-pen{font-family:'Caveat',cursive;font-size:clamp(1.6rem,4.5vw,3rem);color:#1c2a5e;line-height:1.5;white-space:pre-wrap;border-right:2px solid #1c2a5e;width:0;overflow:hidden;animation:type 2.6s steps(38) .4s forwards,blink .7s step-end infinite}
  .e-ink.in .ink-pen{animation-play-state:running}
  @keyframes type{to{width:24ch}}
  @keyframes blink{50%{border-color:transparent}}
  .ink-h{font-family:'Instrument Serif',serif;font-size:clamp(2rem,5vw,3.4rem);margin-bottom:1.5rem}

  /* ---- ERA 2 · CRT (the first runtime) ---- */
  .e-crt{background:radial-gradient(120% 90% at 50% 30%,#0c1810,#040806);color:var(--phos);font-family:'IBM Plex Mono',monospace}
  .e-crt::after{content:"";position:absolute;inset:0;pointer-events:none;background:repeating-linear-gradient(0deg,rgba(0,0,0,.25) 0 2px,transparent 2px 4px);opacity:.5;mix-blend-mode:multiply}
  .e-crt .yr{color:var(--phos)}
  .crt-screen{border:1px solid rgba(134,255,174,.25);border-radius:8px;padding:clamp(1.2rem,4vw,2.4rem);max-width:680px;box-shadow:0 0 60px rgba(134,255,174,.12) inset,0 0 40px rgba(134,255,174,.08);text-shadow:0 0 8px rgba(134,255,174,.6)}
  .crt-line{font-size:clamp(.85rem,2vw,1.1rem);line-height:1.9}
  .crt-line .c{color:var(--amber)}
  .e-crt .cap{color:var(--phos);text-shadow:0 0 8px rgba(134,255,174,.4)}

  /* ---- ERA 3 · TELEMETRY (2020, the scrub) ---- */
  .e-tel{background:#050a0e;color:var(--vec);font-family:'IBM Plex Mono',monospace}
  .e-tel .yr{color:var(--vec)}
  .tel-grid{position:absolute;inset:0;background:
      repeating-linear-gradient(0deg,transparent 0 39px,rgba(95,208,255,.07) 39px 40px),
      repeating-linear-gradient(90deg,transparent 0 39px,rgba(95,208,255,.07) 39px 40px);
    mask:radial-gradient(120% 80% at 60% 50%,#000,transparent 75%)}
  .tel-svg{position:absolute;inset:0;width:100%;height:100%;opacity:.55}
  .tel-svg path{fill:none;stroke:var(--vec);stroke-width:1.2;stroke-dasharray:1400;stroke-dashoffset:1400;transition:stroke-dashoffset 2.4s ease}
  .e-tel.in .tel-svg path{stroke-dashoffset:0}
  .tel-read{position:relative;z-index:2}
  .scrub{color:#ff5a4d;font-size:clamp(2rem,6vw,4rem);letter-spacing:.04em;text-shadow:0 0 20px rgba(255,90,77,.4)}
  .e-tel .cap{color:#cfeeff}

  /* ---- ERA 4 · GPU (now) — the payoff ---- */
  .e-gpu{background:var(--gpu);justify-content:center;align-items:flex-start}
  #gl{position:absolute;inset:0;width:100%;height:100%;z-index:0}
  .caliper-layer{position:absolute;inset:0;z-index:1;pointer-events:none;opacity:0}
  .gpu-hud{position:relative;z-index:2;max-width:900px}
  .gpu-kicker{font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--amber);margin-bottom:1.2rem}
  .gpu-h{font-family:'Instrument Serif',serif;font-size:clamp(2.4rem,6.5vw,5rem);line-height:1.05;letter-spacing:-.01em;text-shadow:0 4px 40px rgba(0,0,0,.7)}
  .gpu-name{font-family:'IBM Plex Mono',monospace;font-size:13px;letter-spacing:.05em;color:#aeb4c0;margin-top:1.6rem}
  .gpu-cta{display:inline-block;margin-top:1.6rem;font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.08em;color:#fff;background:#ff4f1f;padding:.8rem 1.3rem;border-radius:2px;text-decoration:none}

  .cmpbar{position:fixed;left:50%;bottom:1rem;transform:translateX(-50%);z-index:50;display:flex;gap:.5rem;align-items:center;background:rgba(10,10,12,.86);backdrop-filter:blur(8px);border:1px solid #333;border-radius:999px;padding:.4rem .5rem .4rem 1rem;font-family:'IBM Plex Mono',monospace;font-size:10.5px}
  .cmpbar b{color:var(--amber);letter-spacing:.1em}
  .cmpbar a{color:#cfd3da;text-decoration:none;border:1px solid #333;border-radius:999px;padding:.35rem .7rem}
  .cmpbar a:hover{border-color:var(--amber);color:var(--amber)}
  .cmpbar a.here{border-color:var(--amber);color:var(--amber)}
  .scrollcue{position:absolute;bottom:2.2rem;left:7vw;font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.2em;opacity:.6}
  @media(prefers-reduced-motion:reduce){.reveal{opacity:1;transform:none;transition:none}.ink-pen{width:24ch;animation:none;border:none}.tel-svg path{stroke-dashoffset:0}}
</style>
</head>
<body>
  <!-- ERA 1 · INK -->
  <section class="era e-ink reveal" data-era>
    <span class="yr">2014</span>
    <div class="tag">RENDER MODE · INK ON PAPER</div>
    <h2 class="ink-h">My first program.</h2>
    <div class="ink-pen">{"for (life) { build(); }"}</div>
    <p class="cap">Written in ink, in a notebook, with no computer to run it. I executed it in my head.</p>
    <div class="scrollcue">scroll — the renderer upgrades ↓</div>
  </section>

  <!-- ERA 2 · CRT -->
  <section class="era e-crt reveal" data-era>
    <span class="yr">~2016</span>
    <div class="tag">RENDER MODE · CRT PHOSPHOR</div>
    <div class="crt-screen">
      <div class="crt-line">&gt; boot family-laptop<span class="c">_</span></div>
      <div class="crt-line">&gt; net: <span class="c">1/12 of mom's salary</span></div>
      <div class="crt-line">&gt; run first_program.c</div>
      <div class="crt-line"><span class="c">hello, world.</span> finally.</div>
    </div>
    <p class="cap">The first machine I could actually run code on. I counted every gigabyte.</p>
  </section>

  <!-- ERA 3 · TELEMETRY -->
  <section class="era e-tel reveal" data-era>
    <span class="yr">2020</span>
    <div class="tel-grid"></div>
    <svg class="tel-svg" viewBox="0 0 1200 700" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <path d="M0 520 Q 300 510 480 430 T 900 250 L 1200 180" />
      <path d="M0 600 L 280 600 L 320 560 L 700 560 L 740 600 L 1200 600" />
      <path d="M620 0 L 620 700 M 0 350 L 1200 350" stroke-width="0.6" />
    </svg>
    <div class="tel-read">
      <div class="tag">TELEMETRY · NASA ROVER · TEAM BANGLADESH</div>
      <div class="scrub">FLIGHT: SCRUBBED · T-2 DAYS</div>
      <p class="cap">The rover was ready. March 2020 killed the flight. So the team became a ventilator team.</p>
    </div>
  </section>

  <!-- ERA 4 · GPU -->
  <section class="era e-gpu" id="gpu" data-era>
    <canvas id="gl"></canvas>
    <div class="caliper-layer" aria-hidden="true">
      {calKeys.map((k) => (<span data-caliper={k}></span>))}
    </div>
    <div class="gpu-hud reveal">
      <div class="gpu-kicker">RENDER MODE · GPU · 120,000 PARTICLES</div>
      <h1 class="gpu-h">This code finally<br/>has a computer.<br/><em>Yours.</em></h1>
      <div class="gpu-name">{meta.fullName} · Computer Engineering · Rose-Hulman ’28</div>
      <a class="gpu-cta" href="/">← back to the live site</a>
    </div>
  </section>

  <nav class="cmpbar">
    <b>PROTOTYPE</b>
    <a class="here">THE RUN</a>
    <a href="/try/ink/">THE INK →</a>
  </nav>

  <script>
    import { initBrain } from "../../scripts/brain";
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const io = new IntersectionObserver((es) => {
      es.forEach((e) => { if (e.isIntersecting) e.target.classList.add("in"); });
    }, { threshold: 0.25 });
    document.querySelectorAll("[data-era], .gpu-hud").forEach((el) => io.observe(el));

    // mount the GPU-era brain once it's near
    const gpu = document.getElementById("gpu");
    let booted = false;
    const bootBrain = () => {
      if (booted) return; booted = true;
      try {
        initBrain({
          canvas: document.getElementById("gl"),
          caliperLayer: document.querySelector(".caliper-layer"),
          reduceMotion: reduce,
          getScrollT: () => {
            const r = gpu.getBoundingClientRect();
            return Math.min(1, Math.max(0, 1 - r.top / (r.height || innerHeight)));
          },
        });
      } catch (err) { console.warn("brain failed", err); }
    };
    new IntersectionObserver((es) => {
      es.forEach((e) => { if (e.isIntersecting) bootBrain(); });
    }, { rootMargin: "200px" }).observe(gpu);
  </script>
</body>
</html>
