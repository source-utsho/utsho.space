    // ---- particle forms ----
    const N = reduce ? 24000 : (innerWidth < 760 ? 60000 : 120000);
    function fibDir(i: number, n: number) { const inc = Math.PI * (3 - Math.sqrt(5)), y = 1 - 2 * ((i + 0.5) / n), r = Math.sqrt(Math.max(0, 1 - y * y)), phi = i * inc; return [Math.cos(phi) * r, y, Math.sin(phi) * r]; }
    // ------------------------------------------------------------------
    // Procedural human brain — anatomical point cloud (lateral view readable)
    // axes: +X anterior (front) · +Y superior (top) · +Z right hemisphere
    // returns positions with `.aDepth` (0 gyral crest .. 1 sulcus/fissure)
    // ------------------------------------------------------------------
    function buildBrain(): Float32Array {
      const out = new Float32Array(N * 3);
      const depth = new Float32Array(N); // aDepth per point

      // seeded PRNG (mulberry32) — deterministic brain every load
      let _s = (0x9e3779b9 ^ 1337) >>> 0;
      function rng(): number {
        _s |= 0; _s = (_s + 0x6D2B79F5) | 0;
