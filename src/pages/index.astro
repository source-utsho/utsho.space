          idx++; written++;
        }
      }
      // interior volume hint (~8%)
      function buildInterior(count: number): void {
        let written = 0, attempts = 0; const maxA = count * 8;
        while (written < count && attempts < maxA) {
          attempts++;
          const li = (rng() * NCP) | 0; randDir();
          const frac = Math.cbrt(rng()) * 0.84;
          out[idx*3]   = CPX[li] + _dx * CRX[li] * frac;
          out[idx*3+1] = CPY[li] + _dy * CRY[li] * frac;
          out[idx*3+2] = CPZ[li] + _dz * CRZ[li] * frac;
          depth[idx] = 0.72 + rng() * 0.28;
          idx++; written++;
        }
      }

      const nInterior   = Math.round(N * 0.08);
      const nBrainstem  = Math.round(N * 0.03);
      const nCerebellum = Math.round(N * 0.125);
      const nCerebrum   = N - nInterior - nBrainstem - nCerebellum;
      buildCerebrum(nCerebrum);
      buildCerebellum(nCerebellum);
      buildBrainstem(nBrainstem);
      buildInterior(nInterior);
      while (idx < N) buildCerebrum(N - idx);

      (out as any).aDepth = depth;
      return out;
    }
    function buildLattice(): Float32Array {
      const out = new Float32Array(N * 3); const NODES = 84, nodes: number[][] = [];
      for (let i = 0; i < NODES; i++) nodes.push([(Math.random() - 0.5) * 27, (Math.random() - 0.5) * 18, (Math.random() - 0.5) * 12]);
      const edges: number[][] = [];
      for (let a = 0; a < NODES; a++) { const d = nodes.map((n, b) => [b, (n[0]-nodes[a][0])**2 + (n[1]-nodes[a][1])**2 + (n[2]-nodes[a][2])**2]).sort((p, q) => p[1] - q[1]); for (let k = 1; k <= 3; k++) edges.push([a, d[k][0]]); }
      const nodeCount = Math.floor(N * 0.32);
      for (let i = 0; i < N; i++) {
        if (i < nodeCount) { const n = nodes[(Math.random() * NODES) | 0]; out[i*3] = n[0]+(Math.random()-0.5)*1.6; out[i*3+1] = n[1]+(Math.random()-0.5)*1.6; out[i*3+2] = n[2]+(Math.random()-0.5)*1.6; }
        else { const e = edges[(Math.random() * edges.length) | 0], a = nodes[e[0]], b = nodes[e[1]], t = Math.random(); out[i*3] = a[0]+(b[0]-a[0])*t+(Math.random()-0.5)*0.5; out[i*3+1] = a[1]+(b[1]-a[1])*t+(Math.random()-0.5)*0.5; out[i*3+2] = a[2]+(b[2]-a[2])*t+(Math.random()-0.5)*0.5; }
      } return out;
    }
    function buildChip(): Float32Array {
      const out = new Float32Array(N * 3); const W = 14, H = 10, lines: number[][] = [];
      for (let g = -6; g <= 6; g++) { lines.push([0, g * (H / 7)]); lines.push([1, g * (W / 7)]); }
      for (let i = 0; i < N; i++) {
        const r = Math.random(); let x: number, y: number;
        if (r < 0.34) { x = (Math.random() - 0.5) * 11; y = (Math.random() - 0.5) * 9; }
        else if (r < 0.86) { const ln = lines[(Math.random() * lines.length) | 0]; if (ln[0] === 0) { x = (Math.random() - 0.5) * 2 * W; y = ln[1] + (Math.random() - 0.5) * 0.4; } else { x = ln[1] + (Math.random() - 0.5) * 0.4; y = (Math.random() - 0.5) * 2 * H; } }
        else { const side = (Math.random() * 4) | 0; if (side === 0) { x = -W; y = (Math.random() - 0.5) * 2 * H; } else if (side === 1) { x = W; y = (Math.random() - 0.5) * 2 * H; } else if (side === 2) { y = -H; x = (Math.random() - 0.5) * 2 * W; } else { y = H; x = (Math.random() - 0.5) * 2 * W; } }
        out[i*3] = x; out[i*3+1] = y; out[i*3+2] = (Math.random() - 0.5) * 2.2;
      } return out;
    }
    const shapes = [buildBrain(), buildLattice(), buildChip()];
    const labels = ["MIND", "NETWORK", "SILICON"];
    const rand = new Float32Array(N); for (let i = 0; i < N; i++) rand[i] = Math.random();
    // sulcus-depth attribute: only the brain darkens its folds; it morphs like positions
    const brainDepth = (shapes[0] as any).aDepth as Float32Array;
    const zeroDepth = new Float32Array(N);
    const depths = [brainDepth, zeroDepth, zeroDepth];

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: false, powerPreference: "high-performance" });
    renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
    renderer.toneMapping = THREE.ACESFilmicToneMapping; renderer.toneMappingExposure = 1.0;
    const scene = new THREE.Scene(); scene.background = new THREE.Color(0x0A0B0D);
    const camera = new THREE.PerspectiveCamera(50, 1, 0.1, 1000); camera.position.set(0, 0, 66);
    const geo = new THREE.BufferGeometry();
    geo.setAttribute("position", new THREE.BufferAttribute(shapes[0].slice(), 3));
    geo.setAttribute("aFrom", new THREE.BufferAttribute(shapes[0].slice(), 3));
    geo.setAttribute("aTo", new THREE.BufferAttribute(shapes[1].slice(), 3));
    geo.setAttribute("aRand", new THREE.BufferAttribute(rand, 1));
    geo.setAttribute("aDepthFrom", new THREE.BufferAttribute(depths[0].slice(), 1));
    geo.setAttribute("aDepthTo", new THREE.BufferAttribute(depths[1].slice(), 1));
    const uniforms = {
      uMix: { value: 0 }, uTime: { value: 0 }, uSize: { value: 0.92 }, uIntro: { value: 1.0 },
      uMouse: { value: new THREE.Vector3(9999, 9999, 9999) }, uRepelR: { value: 6.5 },
      cCyan: { value: new THREE.Color(0x1DA98E) }, cIndigo: { value: new THREE.Color(0x3F45C0) }, cWhite: { value: new THREE.Color(0x9FD8CB) },
    };
    const NOISE = `
      vec3 mod289(vec3 x){return x-floor(x*(1.0/289.0))*289.0;} vec4 mod289(vec4 x){return x-floor(x*(1.0/289.0))*289.0;}
      vec4 permute(vec4 x){return mod289(((x*34.0)+1.0)*x);} vec4 taylorInvSqrt(vec4 r){return 1.79284291400159-0.85373472095314*r;}
      float snoise(vec3 v){ const vec2 C=vec2(1.0/6.0,1.0/3.0); const vec4 D=vec4(0.0,0.5,1.0,2.0);
        vec3 i=floor(v+dot(v,C.yyy)); vec3 x0=v-i+dot(i,C.xxx); vec3 g=step(x0.yzx,x0.xyz); vec3 l=1.0-g; vec3 i1=min(g.xyz,l.zxy); vec3 i2=max(g.xyz,l.zxy);
        vec3 x1=x0-i1+C.xxx; vec3 x2=x0-i2+C.yyy; vec3 x3=x0-D.yyy; i=mod289(i);
        vec4 p=permute(permute(permute(i.z+vec4(0.0,i1.z,i2.z,1.0))+i.y+vec4(0.0,i1.y,i2.y,1.0))+i.x+vec4(0.0,i1.x,i2.x,1.0));
        float n_=0.142857142857; vec3 ns=n_*D.wyz-D.xzx; vec4 j=p-49.0*floor(p*ns.z*ns.z); vec4 x_=floor(j*ns.z); vec4 y_=floor(j-7.0*x_);
        vec4 x=x_*ns.x+ns.yyyy; vec4 y=y_*ns.x+ns.yyyy; vec4 h=1.0-abs(x)-abs(y); vec4 b0=vec4(x.xy,y.xy); vec4 b1=vec4(x.zw,y.zw);
        vec4 s0=floor(b0)*2.0+1.0; vec4 s1=floor(b1)*2.0+1.0; vec4 sh=-step(h,vec4(0.0)); vec4 a0=b0.xzyw+s0.xzyw*sh.xxyy; vec4 a1=b1.xzyw+s1.xzyw*sh.zzww;
        vec3 p0=vec3(a0.xy,h.x); vec3 p1=vec3(a0.zw,h.y); vec3 p2=vec3(a1.xy,h.z); vec3 p3=vec3(a1.zw,h.w);
        vec4 norm=taylorInvSqrt(vec4(dot(p0,p0),dot(p1,p1),dot(p2,p2),dot(p3,p3))); p0*=norm.x; p1*=norm.y; p2*=norm.z; p3*=norm.w;
        vec4 m=max(0.6-vec4(dot(x0,x0),dot(x1,x1),dot(x2,x2),dot(x3,x3)),0.0); m=m*m; return 42.0*dot(m*m,vec4(dot(p0,x0),dot(p1,x1),dot(p2,x2),dot(p3,x3))); }
      vec3 snoiseVec3(vec3 x){ return vec3(snoise(x), snoise(vec3(x.y-19.1,x.z+33.4,x.x+47.2)), snoise(vec3(x.z+74.2,x.x-124.5,x.y+99.4))); }`;
    const mat = new THREE.ShaderMaterial({
      uniforms, transparent: true, depthWrite: false, blending: THREE.AdditiveBlending,
      vertexShader: NOISE + `
        attribute vec3 aFrom; attribute vec3 aTo; attribute float aRand;
        attribute float aDepthFrom; attribute float aDepthTo;
        uniform float uMix; uniform float uTime; uniform float uSize; uniform float uIntro; uniform vec3 uMouse; uniform float uRepelR;
        varying float vSpeed; varying float vRand; varying float vDepth;
        void main(){
          vec3 p = mix(aFrom, aTo, uMix);
          float env = sin(uMix * 3.14159);
          float amp = 0.45 + env * 4.0 + uIntro * 8.0;
          vec3 disp = snoiseVec3(p * 0.06 + uTime * 0.12) * amp; p += disp;
          vec3 toM = p - uMouse; float md = length(toM); if (md < uRepelR) { p += normalize(toM + 0.001) * (uRepelR - md) * 0.9; }
          float heat = clamp(env * 0.7 + uIntro * 0.8 + (snoise(p * 0.4 + uTime * 0.25) * 0.5 + 0.5) * 0.15, 0.0, 1.0);
          vSpeed = heat; vRand = aRand;
          vDepth = mix(aDepthFrom, aDepthTo, uMix);
          vec4 mv = modelViewMatrix * vec4(p, 1.0);
          gl_PointSize = uSize * (0.5 + aRand * 0.95) * (220.0 / -mv.z);
          gl_Position = projectionMatrix * mv;
        }`,
      fragmentShader: `precision highp float; uniform vec3 cCyan; uniform vec3 cIndigo; uniform vec3 cWhite; varying float vSpeed; varying float vRand; varying float vDepth;
        void main(){ vec2 uv = gl_PointCoord - 0.5; float d = length(uv); if (d > 0.5) discard; float a = smoothstep(0.5, 0.0, d);
          vec3 col = mix(cIndigo, cCyan, vRand); col = mix(col, cWhite, smoothstep(0.72, 1.0, vSpeed) * 0.55);
          col = mix(col, cIndigo * 0.45, vDepth * 0.7);            // sulci sink into deep indigo
          col *= mix(1.0, 0.40, vDepth);                           // fissure self-shadowing
          gl_FragColor = vec4(col, a * 0.3 * (1.0 - vDepth * 0.25)); }`,
    });
    const points = new THREE.Points(geo, mat); scene.add(points);
    const composer = new EffectComposer(renderer);
    composer.addPass(new RenderPass(scene, camera));
    composer.addPass(new UnrealBloomPass(new THREE.Vector2(1, 1), 0.3, 0.4, 0.24));
    composer.addPass(new OutputPass());
    function resize() {
      const w = innerWidth, h = canvas.clientHeight || innerHeight;
      renderer.setSize(w, h, false); composer.setSize(w, h);
      camera.aspect = w / h; camera.updateProjectionMatrix();
      uniforms.uSize.value = w < 700 ? 0.6 : 0.92;
      // place the cloud relative to the visible frustum at z=0 so it sits in the
      // open right half on desktop and the upper third on phones, never cropped
      const halfH = Math.tan((camera.fov * Math.PI) / 360) * 66;
      const halfW = halfH * camera.aspect;
      if (w < 760) { points.position.set(0, halfH * 0.32, 0); points.scale.setScalar(0.6); }
      else { points.position.set(halfW * 0.52, 1.2, 0); points.scale.setScalar(Math.min(1, halfW / 66)); }
    }
    resize(); addEventListener("resize", resize);

    let tmx = 0, tmy = 0, mx = 0, my = 0, ndcX = 9, ndcY = 9;
    addEventListener("pointermove", (e) => { tmx = e.clientX / innerWidth - 0.5; tmy = e.clientY / innerHeight - 0.5; ndcX = (e.clientX / innerWidth) * 2 - 1; ndcY = -(e.clientY / innerHeight) * 2 + 1; });
    const _ray = new THREE.Vector3();
    const order = shapes.length; let curTo = 1, mode: "hold" | "morph" = "hold", timer = 0;
    const HOLD = 3.0, MORPH = 2.0;
    const ease = (k: number) => k < 0.5 ? 4 * k * k * k : 1 - Math.pow(-2 * k + 2, 3) / 2;
    const clock = new THREE.Clock(); formLabel.textContent = labels[0];
    function settle() {
      (geo.getAttribute("aFrom") as THREE.BufferAttribute).array.set(shapes[curTo]); geo.getAttribute("aFrom").needsUpdate = true;
      (geo.getAttribute("aDepthFrom") as THREE.BufferAttribute).array.set(depths[curTo]); geo.getAttribute("aDepthFrom").needsUpdate = true;
      curTo = (curTo + 1) % order;
      (geo.getAttribute("aTo") as THREE.BufferAttribute).array.set(shapes[curTo]); geo.getAttribute("aTo").needsUpdate = true;
      (geo.getAttribute("aDepthTo") as THREE.BufferAttribute).array.set(depths[curTo]); geo.getAttribute("aDepthTo").needsUpdate = true;
      uniforms.uMix.value = 0;
    }
    let heroVisible = true;
    new IntersectionObserver((es) => { heroVisible = es[0].isIntersecting; }).observe(canvas);
    function frame() {
      const raw = clock.getDelta(); const dt = Math.min(raw, 0.05); uniforms.uTime.value += dt; timer += Math.min(raw, 0.5);
      if (uniforms.uIntro.value > 0) uniforms.uIntro.value = Math.max(0, uniforms.uIntro.value - dt / 1.7);
      if (mode === "hold") { if (timer > HOLD) { mode = "morph"; timer = 0; formLabel.textContent = labels[curTo]; } }
      else { const k = Math.min(timer / MORPH, 1); uniforms.uMix.value = ease(k); if (k >= 1) { settle(); mode = "hold"; timer = 0; } }
      mx += (tmx - mx) * 0.04; my += (tmy - my) * 0.04;
      points.rotation.y = mx * 0.5; points.rotation.x = my * 0.3;
      camera.position.x = mx * 6; camera.position.y = -my * 4; camera.lookAt(0, 0, 0); points.updateMatrixWorld(true);
      if (ndcX < 2) { _ray.set(ndcX, ndcY, 0.5).unproject(camera).sub(camera.position).normalize(); const t = -camera.position.z / _ray.z; _ray.multiplyScalar(t).add(camera.position); points.worldToLocal(_ray); uniforms.uMouse.value.copy(_ray); }
      else uniforms.uMouse.value.set(9999, 9999, 9999);
      if (heroVisible) composer.render();
      requestAnimationFrame(frame);
    }
    if (reduce) { uniforms.uIntro.value = 0; composer.render(); pre.classList.add("gone"); }
    else { let pc = 0; const pid = setInterval(() => { pc = Math.min(100, pc + Math.round(2 + Math.random() * 6)); preCount.textContent = String(pc); if (pc >= 100) { clearInterval(pid); pre.classList.add("gone"); } }, 45); requestAnimationFrame(frame); }
  </script>
