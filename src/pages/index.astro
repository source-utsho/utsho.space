---
// BENCH-028 — Utsho Instruments. The portfolio reframed as a precision
// measuring instrument that reads its visitor. Eight channels, one strip-chart.
import SiteLayout from "../layouts/SiteLayout.astro";
import {
  meta, hero, datasheet, experiments, instruments,
  calibration, certifications, benchNotes, contact,
} from "../data/portfolio";

const channels = [
  { id: "ch-01", n: "CH·01", name: "SPECIMEN" },
  { id: "ch-02", n: "CH·02", name: "READOUT" },
  { id: "ch-03", n: "CH·03", name: "EXPERIMENTS" },
  { id: "ch-04", n: "CH·04", name: "INSTRUMENTS" },
  { id: "ch-05", n: "CH·05", name: "CALIBRATION" },
  { id: "ch-06", n: "CH·06", name: "CERTIFICATIONS" },
  { id: "ch-07", n: "CH·07", name: "BENCH NOTES" },
  { id: "ch-08", n: "CH·08", name: "SIGNAL OUT" },
];
const calipers = [
  { key: "prefrontal", label: "DUALMIND" },
  { key: "broca", label: "THE GLOVE" },
  { key: "motor", label: "ROBOSICS" },
  { key: "hippocampus", label: "360 QUESTIONS" },
  { key: "occipital", label: "NEWTON" },
  { key: "cerebellum", label: "ELDER-CARE · PID" },
];
const benchOf: Record<string, string> = {
  glove: "glove", eldercare: "eldercare", robosics: "tremor",
};
---

<SiteLayout>
  <!-- ============ CHROME ============ -->
  <header class="topbar">
    <div class="tb-id">
      <span class="tb-name">{meta.fullName.toUpperCase()}</span>
      <span class="tb-sep">·</span>
      <span class="tb-role">COMPUTER ENGINEERING · ROSE-HULMAN ’28</span>
    </div>
    <nav class="tb-act">
      <button id="readout-btn" class="tb-btn">30-SECOND READOUT</button>
      <a class="tb-btn" href={`mailto:${meta.email}?subject=Résumé request`}>RÉSUMÉ</a>
      <a class="tb-btn tb-mail" href={`mailto:${meta.email}`}>EMAIL</a>
    </nav>
  </header>

  <!-- ============ LEFT RAIL — the oscilloscope channel selector ============ -->
  <aside class="rail">
    <div class="rail-top">
      <span class="rail-serial">{meta.serial}</span>
      <span class="rail-power">● POWER</span>
    </div>
    <div class="rail-trace">
      <canvas id="trace-canvas"></canvas>
      <div class="rail-readout">
        <span id="attn-clock" class="rd-clock">T+00:00</span>
        <span id="attn-class" class="rd-class">AWAITING SUBJECT… move something.</span>
      </div>
    </div>
    <nav class="rail-nav">
      {channels.map((c) => (
        <a class="rn" href={`#${c.id}`} data-nav={c.id}>
          <span class="rn-n">{c.n}</span><span class="rn-name">{c.name}</span>
        </a>
      ))}
    </nav>
  </aside>

  <main class="bench" id="bench-root">

    <!-- ============ CH·01 SPECIMEN ============ -->
    <section class="channel hero" id="ch-01" data-channel="SPECIMEN" aria-label="SPECIMEN">
      <canvas id="gl" class="brain-canvas"></canvas>
      <div class="caliper-layer" aria-hidden="true">
        {calipers.map((c) => (
          <span class="caliper" data-caliper={c.key} data-occluded="1">
            <i class="cdot"></i><b class="clabel">{c.label}</b>
          </span>
        ))}
      </div>
      <div class="hero-hud">
        <div class="hero-tag"><span class="t-dot"></span>{hero.channel} · {hero.channelName} · SUBJECT UNDER EXAMINATION</div>
        <h1 class="hero-h">{hero.headline}</h1>
        <p class="hero-sub">{hero.subline}</p>
        <p class="hero-foot">{hero.footnote}</p>
        <div class="hero-act">
          <a class="btn btn-orange" href="#ch-03">RUN EXPERIMENTS — PLAY THE GAMES</a>
          <a class="btn btn-steel" href="#ch-02">30-SECOND READOUT</a>
        </div>
      </div>
      <a class="scrollcue" href="#ch-02" aria-label="scroll">FEED CHART ↓</a>
    </section>

    <!-- ============ CH·02 READOUT (datasheet / fast path) ============ -->
    <section class="channel" id="ch-02" data-channel="READOUT" aria-label="READOUT">
      <div class="ch-head"><span class="ch-n">{datasheet.channel}</span><h2 class="ch-name">{datasheet.channelName}</h2><span class="ch-rule"></span></div>
      <div class="panel datasheet">
        <div class="ds-top">
          <div>
            <div class="ds-name">{datasheet.name}</div>
            <div class="ds-prog">{datasheet.program}</div>
          </div>
          <div class="ds-tag">{datasheet.tagline}</div>
        </div>
        <div class="gauges">
          {datasheet.gauges.map((g, i) => (
            <figure class="gcell">
              <svg class="gauge" id={`g-${i}`} aria-label={`${g.label} ${g.display ?? g.value}${g.unit}`}></svg>
              <div class="g-display">{g.display ?? g.value}<span class="g-unit">{g.unit}</span></div>
              <figcaption class="g-label">{g.label}</figcaption>
              <p class="g-cap">{g.caption}</p>
            </figure>
          ))}
        </div>
        <div class="ds-act">
          {datasheet.playButtons.map((b) => (
            <a class="btn btn-orange" href={b.href} target="_blank" rel="noopener">{b.label}</a>
          ))}
          <a class="btn btn-steel" href={`mailto:${datasheet.email}?subject=Résumé request`}>{datasheet.resume.label}</a>
          <a class="btn btn-steel" href={`mailto:${datasheet.email}`}>EMAIL</a>
        </div>
        <p class="ds-note">If you have 30 seconds, this panel is the whole site.</p>
      </div>
    </section>

    <!-- ============ CH·03 EXPERIMENTS (the games as sealed chambers) ============ -->
    <section class="channel" id="ch-03" data-channel="EXPERIMENTS" aria-label="EXPERIMENTS">
      <div class="ch-head"><span class="ch-n">{experiments.channel}</span><h2 class="ch-name">{experiments.channelName}</h2><span class="ch-rule"></span></div>
      <p class="ch-intro">{experiments.intro}</p>
      {experiments.entries.map((e) => (
        <article class="experiment">
          <div class="protocol panel">
            <div class="proto-idx">{e.index}</div>
            <h3 class="proto-title">{e.title}</h3>
            <div class="proto-kind">{e.kind} · {e.year}</div>
            <dl class="proto-lines">
              <div><dt>PROTOCOL</dt><dd>{e.protocol}</dd></div>
              <div><dt>HYPOTHESIS</dt><dd>{e.hypothesis}</dd></div>
              <div><dt>APPARATUS</dt><dd>{e.apparatus}</dd></div>
              <div><dt>CITATIONS</dt><dd>{e.citations}</dd></div>
            </dl>
            <div class="proto-badges">{e.badges.map((b) => <span>{b}</span>)}</div>
          </div>
          <div class="chamber panel" data-chamber={e.id} data-src={e.play}>
            <div class="chamber-bezel">
              <span class="chamber-cap">SEALED CHAMBER · {e.controls}</span>
              <button class="power" data-power={e.id}><span class="pw-dot"></span>POWER</button>
            </div>
            <div class="chamber-screen" data-screen={e.id}>
              <div class="chamber-idle">
                <div class="ci-title">{e.title.toUpperCase()}</div>
                <div class="ci-hint">PRESS POWER TO BOOT THE REAL BUILD</div>
              </div>
            </div>
            <a class="chamber-full" href={e.play} target="_blank" rel="noopener">OPEN FULL CHAMBER ↗</a>
          </div>
        </article>
      ))}
      <div class="panel refs">
        <div class="refs-head">REFERENCES · DUALMIND CITES REAL PAPERS</div>
        <ol class="refs-list">
          {experiments.references.map((r) => <li>{r}</li>)}
        </ol>
      </div>
    </section>

    <!-- ============ CH·04 INSTRUMENTS (hardware as bench panels) ============ -->
    <section class="channel" id="ch-04" data-channel="INSTRUMENTS" aria-label="INSTRUMENTS">
      <div class="ch-head"><span class="ch-n">{instruments.channel}</span><h2 class="ch-name">{instruments.channelName}</h2><span class="ch-rule"></span></div>
      <p class="ch-intro">{instruments.intro}</p>
      <div class="inst-grid">
        {instruments.panels.map((p) => (
          <article class="panel inst">
            <div class="inst-top"><span class="inst-idx">{p.index}</span><span class="inst-year">{p.year}</span></div>
            <h3 class="inst-name">{p.name}</h3>
            <div class="inst-kind">{p.kind}</div>
            <div class="inst-headline">{p.headline}</div>
            <div class="inst-mono">
              <p>{p.monoLines[0]}</p>
              <p>{p.monoLines[1]}</p>
            </div>
            {p.honestLine && <p class="inst-honest">{p.honestLine}</p>}
            {benchOf[p.id] && <div class="bench-mount" data-bench={benchOf[p.id]}></div>}
            <table class="inst-tests">
              <tbody>
                {p.tests.map((t) => (
                  <tr><th>{t.param}</th><td>{t.value}</td></tr>
                ))}
              </tbody>
            </table>
          </article>
        ))}
      </div>
    </section>

    <!-- ============ CH·05 CALIBRATION LOG ============ -->
    <section class="channel" id="ch-05" data-channel="CALIBRATION" aria-label="CALIBRATION LOG">
      <div class="ch-head"><span class="ch-n">{calibration.channel}</span><h2 class="ch-name">{calibration.channelName}</h2><span class="ch-rule"></span></div>
      <p class="ch-intro">{calibration.intro}</p>
      <div class="panel callog">
        {calibration.rows.map((r, i) => (
          <div class={`cal-row${r.status ? ` st-${r.status.toLowerCase()}` : ""}`} {...(i === 0 ? { "data-cpu-row": true, tabindex: "0" } : {})}>
            <div class="cal-date">{r.date}</div>
            <div class="cal-body">
              <div class="cal-event">{r.event}{i === 0 && <span class="cal-expand"> — expand ↧</span>}</div>
              {r.readings && <div class="cal-readings">{r.readings.map((x) => <span>{x}</span>)}</div>}
            </div>
            {r.status && <div class={`cal-stamp stamp-${r.status.toLowerCase()}`}>{r.status}</div>}
          </div>
        ))}
        <div class="bench-mount cpu-mount" data-bench="humancpu"></div>
      </div>
    </section>

    <!-- ============ CH·06 CERTIFICATIONS ============ -->
    <section class="channel" id="ch-06" data-channel="CERTIFICATIONS" aria-label="CERTIFICATIONS">
      <div class="ch-head"><span class="ch-n">{certifications.channel}</span><h2 class="ch-name">{certifications.channelName}</h2><span class="ch-rule"></span></div>
      <p class="ch-intro">{certifications.intro}</p>
      <div class="certs">
        {certifications.certs.map((c) => (
          <div class={`cert${c.gold ? " cert-gold" : ""}`}>
            <span class="cert-title">{c.title}</span>
            <span class="cert-org">{c.org}</span>
            <span class="cert-year">{c.year}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ============ CH·07 BENCH NOTES ============ -->
    <section class="channel" id="ch-07" data-channel="BENCH NOTES" aria-label="BENCH NOTES">
      <div class="ch-head"><span class="ch-n">{benchNotes.channel}</span><h2 class="ch-name">{benchNotes.channelName}</h2><span class="ch-rule"></span></div>
      <p class="ch-intro">{benchNotes.intro}</p>
      <div class="notes">
        {benchNotes.notes.map((n) => (
          <article class="note">
            <span class="note-margin">{n.margin}</span>
            <p class="note-body">{n.note}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ============ CH·08 SIGNAL OUT ============ -->
    <footer class="channel" id="ch-08" data-channel="SIGNAL OUT" aria-label="SIGNAL OUT">
      <div class="ch-head"><span class="ch-n">{contact.channel}</span><h2 class="ch-name">{contact.channelName}</h2><span class="ch-rule"></span></div>
      <p class="signal-blurb">{contact.blurb}</p>
      <a class="transmit btn-orange" href={`mailto:${contact.email}`}>{contact.transmitLabel} → {contact.email}</a>
      <div class="signal-links">
        {contact.links.map((l) => <a href={l.href} target="_blank" rel="noopener">{l.label} ↗</a>)}
        <button id="download-trace" class="trace-dl">DOWNLOAD YOUR SESSION TRACE ↧</button>
      </div>
      <div class="mars">{contact.marsCloser}</div>
      <div class="colophon">
        <p>{contact.colophon}</p>
        <p class="bandwidth"><span id="bandwidth">… KB</span> — {contact.bandwidthCaption}</p>
        <p class="set-in">Set in Instrument Serif, obviously. {meta.fullName} · {meta.location} · {meta.serial}.</p>
      </div>
    </footer>
  </main>

  <!-- skim toast -->
  <div id="skim-toast" class="toast" role="status">
    <span>High scan rate detected.</span>
    <a href="#ch-02">The 30-second readout exists for exactly this →</a>
    <button id="toast-x" aria-label="dismiss">✕</button>
  </div>

  <style>
    :root {
      --ground:#0C0D0F; --panel:#141518; --hairline:#2A2D31; --engrave:#E8E6E1;
      --dim:#8A8F98; --amber:#FFB454; --orange:#FF4F1F; --green:#46C28E; --red:#E84B3C; --gold:#D4AF37;
      --mono:'IBM Plex Mono',ui-monospace,monospace; --sans:'IBM Plex Sans',system-ui,sans-serif; --serif:'Instrument Serif',Georgia,serif;
      --rail:64px; --top:46px;
      --eng: 0 1px 0 rgba(0,0,0,.65), 0 -1px 0 rgba(255,255,255,.045);
    }
    @media (min-width:900px){ :root{ --rail:230px; } }
    html{ background:var(--ground); }
    body{ background:var(--ground); color:var(--engrave); font-family:var(--sans); font-size:16px; }
    ::selection{ background:rgba(255,180,84,.28); color:#fff; }
    .mono,.rn,.ch-n{ font-family:var(--mono); }

    /* graph-paper texture used on panels + ground */
    .bench{
      margin-top:var(--top); margin-left:0; min-height:100vh;
      background-image:
        radial-gradient(rgba(255,255,255,.025) .5px, transparent .5px);
      background-size:8px 8px;
    }
    @media (min-width:900px){ .bench{ margin-left:var(--rail); } }

    /* ---------- top chrome ---------- */
    .topbar{ position:fixed; inset:0 0 auto 0; height:var(--top); z-index:60;
      display:flex; align-items:center; justify-content:space-between; gap:1rem;
      padding:0 1rem 0 calc(var(--rail) + 1rem); background:rgba(12,13,15,.92);
      backdrop-filter:blur(8px); border-bottom:1px solid var(--hairline); }
    @media (max-width:899px){ .topbar{ padding:0 .8rem; } }
    .tb-id{ font-family:var(--mono); font-size:10.5px; letter-spacing:.08em; display:flex; gap:.5rem; align-items:baseline; min-width:0; }
    .tb-name{ color:var(--engrave); text-shadow:var(--eng); white-space:nowrap; }
    .tb-sep,.tb-role{ color:var(--dim); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    @media (max-width:620px){ .tb-role,.tb-sep{ display:none; } }
    .tb-act{ display:flex; gap:.45rem; flex-shrink:0; }
    .tb-btn{ font-family:var(--mono); font-size:10px; letter-spacing:.08em; color:var(--dim);
      text-decoration:none; border:1px solid var(--hairline); border-radius:2px; padding:.4rem .6rem;
      background:var(--panel); cursor:pointer; transition:color .2s, border-color .2s; white-space:nowrap; }
    .tb-btn:hover{ color:var(--amber); border-color:var(--amber); }
    .tb-mail{ color:var(--engrave); }
    @media (max-width:620px){ #readout-btn{ display:none; } }

    /* ---------- left rail ---------- */
    .rail{ position:fixed; z-index:55; left:0; top:0; bottom:0; width:var(--rail);
      background:var(--panel); border-right:1px solid var(--hairline);
      display:flex; flex-direction:column; }
    .rail-top{ height:var(--top); display:flex; align-items:center; justify-content:space-between;
      padding:0 .7rem; border-bottom:1px solid var(--hairline); font-family:var(--mono); font-size:9.5px; letter-spacing:.1em; }
    .rail-serial{ color:var(--engrave); text-shadow:var(--eng); }
    .rail-power{ color:var(--green); font-size:8px; }
    .rail-trace{ position:relative; border-bottom:1px solid var(--hairline); }
    #trace-canvas{ display:block; width:100%; height:120px; }
    .rail-readout{ position:absolute; left:.6rem; bottom:.4rem; display:flex; flex-direction:column; gap:2px; pointer-events:none; }
    .rd-clock{ font-family:var(--mono); font-size:10px; color:var(--amber); letter-spacing:.06em; }
    .rd-class{ font-family:var(--mono); font-size:8.5px; color:var(--dim); letter-spacing:.05em; max-width:200px; }
    .rail-nav{ display:flex; flex-direction:column; padding:.5rem 0; overflow-y:auto; }
    .rn{ display:flex; gap:.5rem; align-items:baseline; padding:.42rem .7rem; text-decoration:none;
      border-left:2px solid transparent; transition:background .2s, border-color .2s; }
    .rn:hover{ background:rgba(255,255,255,.025); }
    .rn.active{ border-left-color:var(--amber); background:rgba(255,180,84,.05); }
    .rn-n{ font-family:var(--mono); font-size:9px; color:var(--dim); }
    .rn.active .rn-n{ color:var(--amber); }
    .rn-name{ font-family:var(--mono); font-size:9.5px; letter-spacing:.07em; color:var(--engrave); }
    /* mobile: rail collapses to a top sparkline strip under the topbar */
    @media (max-width:899px){
      .rail{ top:var(--top); bottom:auto; width:100%; height:48px; flex-direction:row; border-right:none; border-bottom:1px solid var(--hairline); }
      .rail-top{ display:none; }
      .rail-trace{ flex:1; border-bottom:none; border-right:1px solid var(--hairline); }
      #trace-canvas{ height:48px; }
      .rail-readout{ bottom:.2rem; }
      .rail-nav{ display:none; }
      .bench{ margin-top:calc(var(--top) + 48px); }
    }

    /* ---------- panels: hairline frame + corner screws + graph paper ---------- */
    .panel{ position:relative; background:
        radial-gradient(circle at 7px 7px, rgba(255,255,255,.05) 1px, transparent 1.4px) no-repeat 0 0,
        radial-gradient(circle at calc(100% - 7px) 7px, rgba(255,255,255,.05) 1px, transparent 1.4px) no-repeat 100% 0,
        radial-gradient(circle at 7px calc(100% - 7px), rgba(255,255,255,.05) 1px, transparent 1.4px) no-repeat 0 100%,
        radial-gradient(circle at calc(100% - 7px) calc(100% - 7px), rgba(255,255,255,.05) 1px, transparent 1.4px) no-repeat 100% 100%,
        var(--panel);
      border:1px solid var(--hairline); border-radius:2px; }

    /* ---------- channels ---------- */
    .channel{ max-width:1100px; margin:0 auto; padding:6rem 1.4rem 3rem; }
    @media (max-width:899px){ .channel{ padding:3.2rem 1rem 2rem; } }
    .ch-head{ display:flex; align-items:baseline; gap:.9rem; border-bottom:1px solid var(--hairline); padding-bottom:.7rem; margin-bottom:1.6rem; }
    .ch-n{ font-size:11px; color:var(--amber); letter-spacing:.1em; }
    .ch-name{ font-family:var(--mono); font-weight:500; font-size:clamp(1rem,2.3vw,1.35rem); letter-spacing:.06em; margin:0; text-shadow:var(--eng); }
    .ch-rule{ flex:1; height:1px; background:repeating-linear-gradient(90deg,var(--hairline) 0 6px,transparent 6px 12px); }
    .ch-intro{ font-family:var(--mono); font-size:12px; color:var(--dim); letter-spacing:.03em; max-width:60ch; margin:0 0 1.8rem; }

    /* ---------- CH01 hero ---------- */
    .hero{ position:relative; min-height:100vh; max-width:none; margin:0; padding:0; display:flex; flex-direction:column; justify-content:center; overflow:hidden; }
    .brain-canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; z-index:0; }
    .caliper-layer{ position:absolute; inset:0; z-index:1; pointer-events:none; }
    .caliper{ position:absolute; top:0; left:0; transform:translate(var(--cx,-300px),var(--cy,-300px)); display:flex; align-items:center; gap:6px; transition:opacity .3s; }
    .caliper[data-occluded="1"]{ opacity:0; }
    .cdot{ width:5px; height:5px; border:1px solid var(--amber); border-radius:50%; box-shadow:0 0 6px rgba(255,180,84,.6); }
    .clabel{ font-family:var(--mono); font-size:9px; font-weight:500; letter-spacing:.1em; color:var(--amber);
      background:rgba(12,13,15,.55); padding:1px 4px; border:1px solid rgba(255,180,84,.25); white-space:nowrap; }
    .hero-hud{ position:relative; z-index:2; max-width:1100px; width:100%; margin:0 auto; padding:0 1.4rem; }
    @media (min-width:900px){ .hero-hud{ padding-left:2.6rem; } }
    .hero-tag{ font-family:var(--mono); font-size:10px; letter-spacing:.16em; color:var(--amber); display:flex; align-items:center; gap:.5rem; margin-bottom:1.2rem; }
    .t-dot{ width:6px; height:6px; border-radius:50%; background:var(--amber); box-shadow:0 0 8px var(--amber); animation:tpulse 1.8s ease-in-out infinite; }
    @keyframes tpulse{ 0%,100%{opacity:.35} 50%{opacity:1} }
    .hero-h{ font-family:var(--serif); font-weight:400; font-size:clamp(2.6rem,7vw,5.4rem); line-height:1.02; letter-spacing:-.01em; margin:0; max-width:18ch; text-shadow:0 4px 40px rgba(0,0,0,.8); }
    .hero-sub{ font-family:var(--serif); font-style:italic; font-size:clamp(1.2rem,2.6vw,1.9rem); color:var(--amber); margin:.6rem 0 0; }
    .hero-foot{ font-family:var(--mono); font-size:10.5px; color:var(--dim); letter-spacing:.04em; margin:1rem 0 0; }
    .hero-act{ display:flex; gap:.7rem; margin-top:2rem; flex-wrap:wrap; }
    .scrollcue{ position:absolute; bottom:1.4rem; left:50%; transform:translateX(-50%); z-index:2; font-family:var(--mono); font-size:9.5px; letter-spacing:.2em; color:var(--dim); text-decoration:none; animation:cue 2s ease-in-out infinite; }
    @keyframes cue{ 0%,100%{opacity:.4;transform:translate(-50%,0)} 50%{opacity:1;transform:translate(-50%,4px)} }

    /* ---------- buttons ---------- */
    .btn{ font-family:var(--mono); font-size:11px; letter-spacing:.07em; text-decoration:none; border-radius:2px; padding:.7rem 1.1rem; cursor:pointer; transition:transform .15s, box-shadow .25s, background .2s, color .2s; display:inline-block; }
    .btn-orange{ background:var(--orange); color:#fff; border:1px solid var(--orange); box-shadow:0 0 0 rgba(255,79,31,0); }
    .btn-orange:hover{ box-shadow:0 6px 26px rgba(255,79,31,.35); transform:translateY(-1px); }
    .btn-steel{ background:var(--panel); color:var(--engrave); border:1px solid var(--hairline); }
    .btn-steel:hover{ border-color:var(--amber); color:var(--amber); }

    /* ---------- CH02 datasheet ---------- */
    .datasheet{ padding:1.6rem; }
    .ds-top{ display:flex; justify-content:space-between; gap:1rem; flex-wrap:wrap; border-bottom:1px solid var(--hairline); padding-bottom:1rem; margin-bottom:1.4rem; }
    .ds-name{ font-family:var(--serif); font-size:1.7rem; }
    .ds-prog{ font-family:var(--mono); font-size:11px; color:var(--dim); letter-spacing:.05em; margin-top:.2rem; }
    .ds-tag{ font-family:var(--serif); font-style:italic; color:var(--amber); font-size:1.1rem; max-width:24ch; text-align:right; }
    .gauges{ display:grid; grid-template-columns:repeat(2,1fr); gap:1.4rem; }
    @media (min-width:760px){ .gauges{ grid-template-columns:repeat(4,1fr); } }
    .gcell{ margin:0; text-align:center; }
    .gauge{ width:100%; max-width:170px; height:auto; display:block; margin:0 auto; }
    .g-display{ font-family:var(--mono); font-size:1.5rem; color:var(--engrave); text-shadow:var(--eng); margin-top:-.4rem; }
    .g-unit{ font-size:.8rem; color:var(--dim); margin-left:1px; }
    .g-label{ font-family:var(--mono); font-size:9.5px; letter-spacing:.1em; color:var(--amber); margin:.2rem 0; }
    .g-cap{ font-family:var(--sans); font-size:11.5px; line-height:1.45; color:var(--dim); margin:.3rem 0 0; }
    .ds-act{ display:flex; gap:.6rem; flex-wrap:wrap; margin-top:1.6rem; }
    .ds-note{ font-family:var(--mono); font-size:10px; color:var(--dim); letter-spacing:.05em; margin:1rem 0 0; }

    /* ---------- CH03 experiments ---------- */
    .experiment{ display:grid; grid-template-columns:1fr; gap:1.1rem; margin-bottom:1.6rem; }
    @media (min-width:880px){ .experiment{ grid-template-columns:minmax(0,1fr) minmax(0,1.1fr); } }
    .protocol{ padding:1.3rem; }
    .proto-idx{ font-family:var(--mono); font-size:10px; letter-spacing:.12em; color:var(--amber); }
    .proto-title{ font-family:var(--serif); font-weight:400; font-size:1.9rem; margin:.2rem 0 0; }
    .proto-kind{ font-family:var(--mono); font-size:10px; color:var(--dim); letter-spacing:.05em; margin-bottom:1rem; }
    .proto-lines div{ display:grid; grid-template-columns:84px 1fr; gap:.7rem; padding:.5rem 0; border-top:1px solid var(--hairline); }
    .proto-lines dt{ font-family:var(--mono); font-size:9px; letter-spacing:.1em; color:var(--dim); }
    .proto-lines dd{ font-family:var(--sans); font-size:12.5px; line-height:1.5; margin:0; color:var(--engrave); }
    .proto-badges{ display:flex; flex-wrap:wrap; gap:.4rem; margin-top:1rem; }
    .proto-badges span{ font-family:var(--mono); font-size:9px; letter-spacing:.05em; color:var(--amber); border:1px solid rgba(255,180,84,.3); border-radius:999px; padding:.25rem .55rem; }
    .chamber{ padding:1rem; display:flex; flex-direction:column; }
    .chamber-bezel{ display:flex; align-items:center; justify-content:space-between; margin-bottom:.7rem; }
    .chamber-cap{ font-family:var(--mono); font-size:9px; letter-spacing:.08em; color:var(--dim); }
    .power{ font-family:var(--mono); font-size:10px; letter-spacing:.1em; color:#fff; background:var(--orange);
      border:1px solid var(--orange); border-radius:2px; padding:.4rem .7rem; cursor:pointer; display:flex; align-items:center; gap:.4rem; }
    .power:hover{ box-shadow:0 4px 18px rgba(255,79,31,.4); }
    .pw-dot{ width:6px; height:6px; border-radius:50%; background:#fff; }
    .chamber-screen{ position:relative; aspect-ratio:16/10; background:#05070c; border:1px solid var(--hairline);
      display:flex; align-items:center; justify-content:center; overflow:hidden; }
    .chamber-screen iframe{ position:absolute; inset:0; width:100%; height:100%; border:0; }
    .chamber-idle{ text-align:center; }
    .ci-title{ font-family:var(--serif); font-size:1.6rem; color:var(--dim); }
    .ci-hint{ font-family:var(--mono); font-size:9px; letter-spacing:.12em; color:var(--amber); margin-top:.4rem; }
    .chamber-boot{ font-family:var(--mono); font-size:10px; line-height:1.7; color:var(--amber); padding:1rem; text-align:left; white-space:pre-wrap; align-self:flex-start; }
    .chamber-full{ font-family:var(--mono); font-size:10px; letter-spacing:.06em; color:var(--dim); text-decoration:none; margin-top:.7rem; align-self:flex-end; }
    .chamber-full:hover{ color:var(--amber); }
    .refs{ padding:1.2rem 1.4rem; }
    .refs-head{ font-family:var(--mono); font-size:10px; letter-spacing:.1em; color:var(--amber); margin-bottom:.8rem; }
    .refs-list{ margin:0; padding-left:1.4rem; }
    .refs-list li{ font-family:var(--mono); font-size:11px; line-height:1.7; color:var(--dim); padding-left:.3rem; }

    /* ---------- CH04 instruments ---------- */
    .inst-grid{ display:grid; grid-template-columns:1fr; gap:1.1rem; }
    @media (min-width:820px){ .inst-grid{ grid-template-columns:1fr 1fr; } }
    .inst{ padding:1.3rem; }
    .inst-top{ display:flex; justify-content:space-between; font-family:var(--mono); font-size:9.5px; letter-spacing:.08em; }
    .inst-idx{ color:var(--amber); } .inst-year{ color:var(--dim); }
    .inst-name{ font-family:var(--serif); font-weight:400; font-size:1.5rem; margin:.3rem 0 0; }
    .inst-kind{ font-family:var(--mono); font-size:9.5px; color:var(--dim); letter-spacing:.05em; }
    .inst-headline{ font-family:var(--mono); font-size:13px; color:var(--engrave); text-shadow:var(--eng); margin:.9rem 0; letter-spacing:.02em; }
    .inst-mono p{ font-family:var(--sans); font-size:12.5px; line-height:1.55; color:var(--dim); margin:.3rem 0; }
    .inst-honest{ font-family:var(--serif); font-style:italic; font-size:1.02rem; line-height:1.4; color:var(--red); margin:1rem 0; padding-left:.8rem; border-left:2px solid var(--red); }
    .bench-mount{ margin:1rem 0; }
    .inst-tests{ width:100%; border-collapse:collapse; margin-top:1rem; }
    .inst-tests tr{ border-top:1px solid var(--hairline); }
    .inst-tests th{ font-family:var(--mono); font-size:10px; font-weight:400; text-align:left; color:var(--dim); letter-spacing:.05em; padding:.45rem 0; }
    .inst-tests td{ font-family:var(--mono); font-size:11px; text-align:right; color:var(--engrave); padding:.45rem 0; }

    /* ---------- CH05 calibration ---------- */
    .callog{ padding:.4rem 1.2rem; }
    .cal-row{ display:grid; grid-template-columns:84px 1fr auto; gap:1rem; align-items:start; padding:.9rem 0; border-top:1px solid var(--hairline); }
    .cal-row:first-child{ border-top:none; }
    .cal-row[data-cpu-row]{ cursor:pointer; }
    .cal-row[data-cpu-row]:hover{ background:rgba(255,255,255,.02); }
    .cal-date{ font-family:var(--mono); font-size:11px; color:var(--amber); letter-spacing:.04em; }
    .cal-event{ font-family:var(--mono); font-size:12.5px; color:var(--engrave); letter-spacing:.02em; }
    .cal-expand{ color:var(--dim); font-size:10px; }
    .cal-readings{ display:flex; flex-wrap:wrap; gap:.4rem .9rem; margin-top:.4rem; }
    .cal-readings span{ font-family:var(--mono); font-size:10px; color:var(--dim); }
    .cal-stamp{ font-family:var(--mono); font-size:9px; letter-spacing:.12em; padding:.2rem .45rem; border:1px solid currentColor; border-radius:2px; align-self:center; }
    .stamp-pass{ color:var(--green); } .stamp-ok{ color:var(--amber); } .stamp-fail{ color:var(--red); } .stamp-pivot{ color:var(--engrave); }
    .st-fail .cal-event{ color:var(--red); }

    /* ---------- CH06 certifications ---------- */
    .certs{ display:flex; flex-direction:column; }
    .cert{ display:grid; grid-template-columns:1fr auto; gap:.5rem 1rem; align-items:baseline; padding:.85rem 0; border-top:1px solid var(--hairline); }
    .cert-title{ font-family:var(--sans); font-size:14px; color:var(--engrave); }
    .cert-org{ font-family:var(--mono); font-size:10px; color:var(--dim); letter-spacing:.04em; grid-column:1; }
    .cert-year{ font-family:var(--mono); font-size:11px; color:var(--dim); grid-row:1; grid-column:2; }
    .cert-gold .cert-title{ color:var(--gold); }
    .cert-gold{ border-top-color:rgba(212,175,55,.4); }

    /* ---------- CH07 bench notes ---------- */
    .notes{ display:grid; grid-template-columns:1fr; gap:1.4rem; }
    @media (min-width:760px){ .notes{ grid-template-columns:1fr 1fr; } }
    .note{ display:grid; grid-template-columns:auto 1fr; gap:1rem; }
    .note-margin{ font-family:var(--mono); font-size:9.5px; letter-spacing:.08em; color:var(--amber); writing-mode:vertical-rl; transform:rotate(180deg); border-left:1px solid var(--hairline); padding-left:.4rem; }
    .note-body{ font-family:var(--serif); font-size:1.15rem; line-height:1.45; color:var(--engrave); margin:0; font-style:italic; }

    /* ---------- CH08 signal out ---------- */
    #ch-08{ border-top:1px solid var(--hairline); }
    .signal-blurb{ font-family:var(--sans); font-size:15px; line-height:1.6; color:var(--dim); max-width:54ch; margin:0 0 1.6rem; }
    .transmit{ display:inline-block; font-family:var(--mono); font-size:clamp(.9rem,2.4vw,1.3rem); letter-spacing:.04em; color:#fff; background:var(--orange); border:1px solid var(--orange); border-radius:2px; padding:.8rem 1.2rem; text-decoration:none; }
    .transmit:hover{ box-shadow:0 8px 30px rgba(255,79,31,.35); }
    .signal-links{ display:flex; gap:1.4rem; flex-wrap:wrap; margin:1.6rem 0; align-items:center; }
    .signal-links a, .trace-dl{ font-family:var(--mono); font-size:12px; color:var(--dim); text-decoration:none; letter-spacing:.04em; background:none; border:none; cursor:pointer; }
    .signal-links a:hover, .trace-dl:hover{ color:var(--amber); }
    .mars{ font-family:var(--mono); font-size:clamp(11px,2vw,13px); letter-spacing:.06em; color:var(--engrave); border:1px dashed var(--hairline); border-radius:2px; padding:1rem 1.2rem; margin:1.4rem 0; text-shadow:var(--eng); }
    .colophon{ border-top:1px solid var(--hairline); padding-top:1.2rem; }
    .colophon p{ font-family:var(--mono); font-size:10px; color:var(--dim); letter-spacing:.03em; line-height:1.7; margin:.2rem 0; }
    .bandwidth #bandwidth{ color:var(--amber); }

    /* ---------- toast ---------- */
    .toast{ position:fixed; right:1rem; bottom:1rem; z-index:80; background:var(--panel); border:1px solid var(--amber);
      border-radius:2px; padding:.8rem 1rem; display:none; align-items:center; gap:.8rem; max-width:340px;
      font-family:var(--mono); font-size:11px; box-shadow:0 10px 40px rgba(0,0,0,.5); }
    .toast.show{ display:flex; }
    .toast span{ color:var(--engrave); } .toast a{ color:var(--amber); text-decoration:none; }
    #toast-x{ background:none; border:none; color:var(--dim); cursor:pointer; font-size:13px; }

    @media (prefers-reduced-motion:reduce){
      .t-dot,.scrollcue{ animation:none; }
      html{ scroll-behavior:auto; }
    }
  </style>

  <script>
    import { initBrain } from "../scripts/brain";
    import { initInstrument } from "../scripts/instrument";
    import { makeGauge } from "../scripts/gauge";
    import { initBenchTests } from "../scripts/benchtests";

    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const $ = <T extends Element = HTMLElement>(s: string) => document.querySelector(s) as T | null;
    const $$ = <T extends Element = HTMLElement>(s: string) => Array.from(document.querySelectorAll(s)) as T[];

    // ---- subject-trace instrument (the rail EEG) ----
    const sections = $$<HTMLElement>(".channel");
    const inst = initInstrument({
      traceCanvas: $("#trace-canvas") as HTMLCanvasElement,
      classEl: $("#attn-class") as HTMLElement,
      clockEl: $("#attn-clock") as HTMLElement,
      channelEls: sections,
      onSkim: () => showToast(),
      reduceMotion: reduce,
    });

    // ---- brain specimen (hero) ----
    const heroEl = $("#ch-01") as HTMLElement;
    const heroT = () => {
      const r = heroEl.getBoundingClientRect();
      const h = r.height || innerHeight;
      return Math.min(1, Math.max(0, -r.top / h));
    };
    let brain: { dispose(): void } | null = null;
    const bootBrain = () => {
      try {
        brain = initBrain({
          canvas: $("#gl") as HTMLCanvasElement,
          caliperLayer: $(".caliper-layer") as HTMLElement,
          reduceMotion: reduce,
          getScrollT: heroT,
        });
      } catch (e) { console.warn("brain init failed", e); }
    };
    if ("requestIdleCallback" in window) (window as any).requestIdleCallback(bootBrain, { timeout: 1200 });
    else setTimeout(bootBrain, 200);

    // ---- datasheet gauges: sweep needles when CH02 enters view ----
    const gaugeData = [
      { value: 200, min: 0, max: 200, unit: "+", decimals: 0 },
      { value: 7, min: 0, max: 20, unit: "s", decimals: 1 },
      { value: 250, min: 0, max: 250, unit: "", decimals: 0 },
      { value: 1000, min: 0, max: 1000, unit: "°", decimals: 0 },
    ];
    const gauges = gaugeData.map((g, i) => {
      const svg = $(`#g-${i}`) as unknown as SVGSVGElement | null;
      return svg ? makeGauge(svg, { ...g, reduceMotion: reduce }) : null;
    });
    let gaugesSwept = false;
    const ds = $("#ch-02") as HTMLElement;
    new IntersectionObserver((es) => {
      es.forEach((e) => {
        if (e.isIntersecting && !gaugesSwept) {
          gaugesSwept = true;
          gauges.forEach((g, i) => g && setTimeout(() => g.set(gaugeData[i].value), 120 * i));
        }
      });
    }, { threshold: 0.3 }).observe(ds);

    // ---- runnable bench tests (eldercare / glove / tremor / human-cpu) ----
    try { initBenchTests($("#bench-root") as HTMLElement, { reduceMotion: reduce }); }
    catch (e) { console.warn("benchtests init failed", e); }

    // ---- game chambers: lazy-boot the real wasm builds on POWER ----
    $$<HTMLButtonElement>(".power").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.getAttribute("data-power")!;
        const chamber = $(`.chamber[data-chamber="${id}"]`) as HTMLElement;
        const screen = chamber.querySelector(`[data-screen="${id}"]`) as HTMLElement;
        const src = chamber.getAttribute("data-src")!;
        if (screen.querySelector("iframe")) return;
        btn.setAttribute("disabled", "true");
        const isJvm = id === "dualmind";
        const log = isJvm
          ? "● POWER ON\n› booting a full Java VM in your tab (CheerpJ → WebAssembly)\n› 0 libraries · 0 asset files\n› loading runtime…"
          : "● POWER ON\n› booting a Python runtime (Pygame → WebAssembly via pygbag)\n› 360-question adaptive bank\n› loading runtime…";
        screen.innerHTML = `<pre class="chamber-boot">${log}</pre>`;
        setTimeout(() => {
          const f = document.createElement("iframe");
          f.src = src; f.setAttribute("allow", "autoplay; fullscreen"); f.title = id;
          screen.innerHTML = ""; screen.appendChild(f);
        }, 900);
      });
    });

    // ---- rail nav active state ----
    const navById: Record<string, HTMLElement> = {};
    $$<HTMLElement>(".rn").forEach((a) => { navById[a.getAttribute("data-nav")!] = a; });
    const navObs = new IntersectionObserver((es) => {
      es.forEach((e) => {
        if (e.isIntersecting) {
          $$<HTMLElement>(".rn").forEach((a) => a.classList.remove("active"));
          navById[(e.target as HTMLElement).id]?.classList.add("active");
        }
      });
    }, { rootMargin: "-35% 0px -60% 0px", threshold: 0 });
    sections.forEach((s) => navObs.observe(s));

    // ---- 30-second readout button + skim toast ----
    const toast = $("#skim-toast") as HTMLElement;
    let toastShown = false;
    function showToast() {
      if (toastShown) return; toastShown = true;
      toast.classList.add("show");
      setTimeout(() => toast.classList.remove("show"), 9000);
    }
    $("#toast-x")?.addEventListener("click", () => toast.classList.remove("show"));
    $("#readout-btn")?.addEventListener("click", () => $("#ch-02")?.scrollIntoView({ behavior: reduce ? "auto" : "smooth" }));

    // ---- session-trace souvenir download ----
    $("#download-trace")?.addEventListener("click", () => {
      const blob = new Blob([inst.exportSVG()], { type: "image/svg+xml" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url; a.download = "session-record.svg"; a.click();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    });

    // ---- live bandwidth ledger ----
    function bytes() {
      try {
        const all = [...performance.getEntriesByType("navigation"), ...performance.getEntriesByType("resource")] as PerformanceResourceTiming[];
        return all.reduce((s, e) => s + (e.transferSize || e.encodedBodySize || 0), 0);
      } catch { return 0; }
    }
    const bw = $("#bandwidth");
    const renderBw = () => { if (bw) bw.textContent = `${Math.round(bytes() / 1024)} KB`; };
    addEventListener("load", () => { renderBw(); setTimeout(renderBw, 2500); });
    renderBw();

    // ---- keyboard navigation (the games are keyboard-first; so is the site) ----
    addEventListener("keydown", (e) => {
      if (e.metaKey || e.ctrlKey || e.altKey) return;
      const tag = (e.target as HTMLElement)?.tagName;
      if (tag === "INPUT" || tag === "TEXTAREA") return;
      const k = e.key.toLowerCase();
      if (k >= "1" && k <= "8") $(`#ch-0${k}`)?.scrollIntoView({ behavior: reduce ? "auto" : "smooth" });
      else if (k === "0") scrollTo({ top: 0, behavior: reduce ? "auto" : "smooth" });
      else if (k === "r") $("#ch-02")?.scrollIntoView({ behavior: reduce ? "auto" : "smooth" });
      else if (k === "d" || k === "n") {
        $("#ch-03")?.scrollIntoView({ behavior: reduce ? "auto" : "smooth" });
        const id = k === "d" ? "dualmind" : "newton";
        setTimeout(() => ($(`.power[data-power="${id}"]`) as HTMLButtonElement)?.click(), 600);
      }
    });
  </script>
</SiteLayout>
