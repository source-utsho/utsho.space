---
interface Props { title?: string; description?: string; }
const {
  title = "H.M. Ibtihal Utsho — BENCH-028 · an instrument that reads you back",
  description = "Computer Engineering at Rose-Hulman. A portfolio built as a measuring instrument: it reads your cursor, charts your visit, and hands the recording back. Two browser-playable games, assistive hardware, and a brain you can scan.",
} = Astro.props;
const canonical = "https://utsho.space";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="utsho.space" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#0C0D0F" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { margin: 0; -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
      a { color: inherit; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
